# =====================================================
# Cidade na Mão — variáveis de ambiente do frontend (Vite)
# =====================================================
# Copie para .env.local (local/teste) e configure no Vercel (produção).

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key
VITE_APP_URL=http://localhost:5173
VITE_EXTERNAL_API_URL=https://api.sasi.io

# -----------------------------------------------------
# Separação TESTE x PRODUÇÃO (banco único)
# -----------------------------------------------------
# true  → ambiente de teste/desenvolvimento (is_test = true)
# false → produção (is_test = false)
#
# Local/teste (.env.local):  VITE_IS_TEST=true
# Produção (Vercel):         VITE_IS_TEST=false
VITE_IS_TEST=true
