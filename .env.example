VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRmdXB3eXR6cmtwem9jZnhoZWVxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3MDA3NTIsImV4cCI6MjA5NzI3Njc1Mn0.Djwm7L_NdO0GKpEK9WIJ5kw0s5mQpiRodsEDtlhqF3M
VITE_APP_URL=http://localhost:5173
VITE_EXTERNAL_API_URL=https://api.sasi.io

# -----------------------------------------------------
# Separação TESTE x PRODUÇÃO (banco único)
# -----------------------------------------------------
# true  → ambiente de teste/desenvolvimento (is_test = true)
# false → produção (is_test = false)
#
# Local/teste (.env.local):  VITE_IS_TEST=true
# Produção (Vercel):         VITE_IS_TEST=false
VITE_IS_TEST=true

# -----------------------------------------------------
# Modo de integração web (telas /web/* espelhadas em sistema externo)
# -----------------------------------------------------
# true  → as telas /web/* NÃO exigem login próprio do SASI (sem tela de login,
#         sem redirect, sem bloqueio por ausência de sessão local). A validação
#         visual é do sistema externo que espelha o SASI.
# false → comportamento padrão (acesso web via token SASI + role admin).
#
# SEGURANÇA: este modo NÃO afrouxa as RPCs administrativas — elas continuam
# exigindo `authenticated` + role admin (RLS/current_user_role). Sem credencial
# válida, leituras permitidas carregam e ações admin falham com mensagem
# amigável (nunca login/sucesso falso). `service_role` jamais vai ao frontend.
#
# INTEGRAÇÃO PENDENTE: para que as AÇÕES admin funcionem embutidas, o sistema
# externo precisa injetar contexto seguro — ex.: token SASI na URL
# (/web/eventos?token=...) trocado por sessão Supabase pelo SasiSessionBoundary.
VITE_WEB_EMBED_MODE=false

# -----------------------------------------------------
# Modo web PÚBLICO por tenant (telas /web/* sem autenticação)
# -----------------------------------------------------
# true  → /web/* opera SEM login, usando o tenant da URL (?tenant=slug) como
#         contexto. Ex.: /web/eventos?tenant=paje. Qualquer pessoa com a URL do
#         tenant pode operar aquele tenant. Os services passam a usar as RPCs
#         web públicas por tenant (web_*_by_tenant).
# false → comportamento padrão (acesso web por sessão/admin).
#
# SEGURANÇA: só as RPCs web_*_by_tenant são liberadas para anon; as RPCs admin
# atuais continuam restritas a authenticated. O isolamento por tenant é feito
# DENTRO das RPCs (resolvem por slug, validam ativo, nunca cruzam tenants).
# Requer a migration 202607020001_web_public_tenant_rpcs.sql aplicada.
# `service_role` jamais vai ao frontend.
VITE_WEB_PUBLIC_MODE=false
